# Copy to .env and fill in values

OPENROUTER_API_KEY=
# Required for Rafeeq AI Medical Assistant (POST /api/ai/chat)
GEMINI_API_KEY=
# Required for driving-route polylines (Directions API, server-side proxy)
GOOGLE_MAPS_API_KEY=
JWT_SECRET=CHANGE_ME_RAFEEQ_JWT_SECRET

# MongoDB (pharmacy inventory uses the same DB as the main app)
MONGODB_URI=mongodb://127.0.0.1:27017/rafeeq_db
